# SariSari Snaps — front-end env (Vite). Copy to .env.local and fill in.
# Only NON-secret, client-safe values belong here.
# The Mailchimp API key is a SERVER secret — it goes in the Apps Script, never here.

# Google Apps Script Web App URL (Phases 2–3). Leave empty for mock mode.
VITE_APPS_SCRIPT_URL=

# Drive parent folder name for saved photos.
VITE_DRIVE_PARENT_FOLDER=Sari Sari Orders

# Shared token the Apps Script checks on every request — must match SHARED_TOKEN
# in apps-script/Code.gs. Not a real secret (it ships in the public bundle), just
# a speed bump against bots scanning for open Apps Script endpoints.
VITE_API_TOKEN=
